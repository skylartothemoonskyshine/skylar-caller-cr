# Skylar Caller CRM — Twilio credentials
# Copy to .env and fill in. Never commit the real .env to git.

# 1) From Twilio Console home (console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2) Create an API Key at Account → API keys & tokens → Create API Key
#    Use type "Standard". Save the SID and SECRET.
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 3) Buy a phone number at Phone Numbers → Buy a Number.
#    Must support Voice + SMS. Use E.164 format (+1...).
TWILIO_FROM_NUMBER=+15555550123

# 4) Create a TwiML App at Voice → TwiML → TwiML Apps → Create new TwiML App.
#    Set Voice Request URL to:    https://your-deployment.vercel.app/api/voice
#    For local testing with ngrok: https://xxx.ngrok.io/api/voice
#    Then copy the TwiML App SID here.
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 5) The public URL your server is reachable at (for recording callbacks).
#    Local dev with ngrok: https://xxx.ngrok.io
#    Production: https://your-deployment.vercel.app
PUBLIC_URL=http://localhost:5173

# Optional: which identity the Voice SDK tokens are issued to.
# Leave as default unless you have a multi-tenant need.
TWILIO_IDENTITY=skylar-caller

# 6) Supabase — server-side webhooks (recordings, inbound SMS) write to Postgres
#    using the service-role key. Get it at Dashboard → Settings → API → service_role.
#    NEVER expose the service-role key to the browser; only use in /api/*.
SUPABASE_URL=https://ukojlspznrrjnoeuxacw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx...service_role_key_here
